{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ClinicKitDb;User Id=sa;Password=P@55w0rd;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "CHANGE_ME_TO_A_STRONG_32_CHAR_KEY_!!",
    "Issuer": "ClinicKit",
    "Audience": "ClinicKitClients",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                        "Warning",
        "Microsoft.Hosting.Lifetime":       "Information",
        "Microsoft.EntityFrameworkCore":    "Warning",
        "System":                           "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/clinickit-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "Application": "ClinicKit"
    }
  },
  "AllowedHosts": "*"
}
